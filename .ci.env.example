# CI/CD — GitHub Actions Secrets
#
# Эти переменные НЕ грузятся как файл.
# Каждую нужно добавить вручную:
#   GitHub → Settings → Secrets and variables → Actions → New repository secret
#
# Шаблон: скопируй, заполни значения, добавь по одному в GitHub UI.

# ── Docker Hub ────────────────────────────────────────────────────────────────
# Логин Docker Hub (не email — именно username)
DOCKERHUB_USERNAME=

# Access token (не пароль аккаунта)
# Создать: hub.docker.com → Account Settings → Security → New Access Token
# Права: Read & Write
DOCKERHUB_TOKEN=

# ── GitHub Actions (авто) ─────────────────────────────────────────────────────
# GITHUB_TOKEN — предоставляется GitHub автоматически, добавлять не нужно.
# Используется в update-manifests для git push.
# Убедиться что включены права: Settings → Actions → General →
#   Workflow permissions → Read and write permissions

# ── ArgoCD (опционально) ──────────────────────────────────────────────────────
# Нужны только если добавить шаг "argocd app wait" в pipeline
# для ожидания завершения синхронизации кластера.

# URL ArgoCD сервера (без https://)
# ARGOCD_SERVER=argocd.your-domain.com

# Auth token: ArgoCD UI → User Info → Generate Token
# или: argocd account generate-token --account github-ci
# ARGOCD_AUTH_TOKEN=
